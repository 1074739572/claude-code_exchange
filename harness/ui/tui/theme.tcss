/* Usage | Chat | Meta | Prompt — merged history layout */

Screen {
    layout: vertical;
    background: $surface;
}

#usage-bar {
    dock: top;
    height: 1;
    background: $primary-darken-2;
    color: $text;
    padding: 0 1;
}

#chat-pane {
    height: 1fr;
    border: solid $accent;
    border-title-color: $accent;
    padding: 0 1;
    scrollbar-gutter: stable;
}

#chat-stream {
    width: 100%;
    height: auto;
    layout: vertical;
}

.bubble-user {
    color: $secondary;
    text-style: bold;
    margin: 1 0 0 0;
}

.bubble-step {
    color: $text-muted;
    margin: 0 0 0 1;
}

.bubble-assistant {
    margin: 1 0 1 0;
    padding: 0 1;
    background: $boost;
    border-left: thick $accent;
}

.bubble-system {
    color: $text-muted;
    text-style: italic;
    margin: 1 0;
}

.welcome-brand {
    height: auto;
    width: 100%;
    margin: 1 0 1 0;
    layout: horizontal;
    align: left middle;
}

.welcome-smiley {
    width: auto;
    height: auto;
    color: #E6B84D;
    text-style: bold;
    margin: 0 2 0 0;
}

.welcome-titles {
    width: 1fr;
    height: auto;
    layout: vertical;
    align: left middle;
}

.welcome-hello {
    width: auto;
    height: auto;
    color: #7FDBFF;
    text-style: bold;
}

.welcome-tagline {
    width: auto;
    height: auto;
    color: #7FDBFF 55%;
    margin: 0 0 0 0;
}

.welcome-narrow {
    color: #7FDBFF;
    text-style: bold;
    margin: 1 0 1 0;
}

.welcome-quote-card {
    width: 100%;
    height: auto;
    margin: 0 0 1 0;
    padding: 0 1 0 2;
    border-left: tall #E6B84D;
    background: #E6B84D 8%;
}

.welcome-quote-label {
    width: 100%;
    color: #E6B84D 70%;
    text-style: bold;
    margin: 0 0 0 0;
}

.welcome-quote-body {
    width: 100%;
    color: #F5F0E6;
    text-style: bold;
    margin: 0 0 0 0;
}

.welcome-quote-source {
    width: 100%;
    color: #E6B84D 55%;
    text-align: right;
    margin: 0 0 0 0;
}

.welcome-rule {
    width: 100%;
    height: 1;
    margin: 0 0 1 0;
}

#footer-stack {
    dock: bottom;
    height: auto;
    border-top: solid $primary-darken-2;
    padding: 0 1 1 1;
}

#meta-bar {
    height: 1;
    margin: 0 0 1 0;
    align: left middle;
}

#meta-model,
#meta-mode {
    color: $primary;
}

#meta-status {
    width: 1fr;
    color: $text-muted;
    text-align: right;
}

#pick-panel {
    height: auto;
    max-height: 14;
    margin: 0 0 1 0;
    background: $boost;
    border: solid $primary-darken-1;
}

#pick-title {
    height: 1;
    text-style: bold;
    color: $primary;
    padding: 0 1;
}

#pick-list {
    height: auto;
    max-height: 11;
    padding: 0 1;
}

#pick-hint {
    height: 1;
    color: $text-muted;
    padding: 0 1;
}

#composer-row {
    height: auto;
    width: 100%;
    layout: horizontal;
    align: left middle;
}

#user-input {
    width: 1fr;
    margin: 0 1 0 0;
}

#send-stop-btn {
    width: 10;
    min-width: 8;
}

AllowModal {
    align: center middle;
}

#allow-dialog {
    width: 72;
    max-width: 90%;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: thick $warning;
    padding: 1 2;
}

#allow-title {
    text-style: bold;
    color: $warning;
    margin-bottom: 1;
}

#allow-detail {
    color: $text;
    margin-bottom: 1;
}

#allow-hint {
    color: $text-muted;
}
