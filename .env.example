# DeepSeek (Anthropic-compatible)
DEEPSEEK_API_KEY=your-deepseek-key
# Or reuse legacy names:
# ANTHROPIC_API_KEY=your-deepseek-key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 智谱 GLM (Anthropic-compatible)
ZHIPU_API_KEY=your-zhipu-key

# 通义千问 (OpenAI-compatible)
DASHSCOPE_API_KEY=your-dashscope-key

# Default model id (must match config/models.json)
MODEL_ID=deepseek-v4-flash

# Optional fallback model id on 529 overload
# FALLBACK_MODEL_ID=deepseek-v4-flash

# Project handbook (HARNESS.md / AGENTS.md) — default on
# HARNESS_PROJECT_MD=0
# HARNESS_PROJECT_MD_MAX_CHARS=12000
# HARNESS_PROJECT_MD_MAX_DEPTH=10

# Agent context/cache: tool results are frozen before they enter history.
# Oversized output is persisted under .task_outputs/tool-results with a stable
# head/tail preview. A parallel tool round also shares a total output budget.
# HARNESS_TOOL_RESULT_MAX_CHARS=12000
# HARNESS_TOOL_ROUND_MAX_CHARS=40000
# Full-history compaction is a checkpoint near the model context limit.
# HARNESS_AUTOCOMPACT_PCT=83.5
# HARNESS_CONTEXT_LIMIT=120000

# Optional PDF image understanding (OpenAI-compatible VLM; sending documents
# to this endpoint is opt-in and may have cost/privacy implications).
HARNESS_RAG_VLM_MODEL=qwen3.6-flash
HARNESS_RAG_VLM_API_KEY=your-vlm-key
HARNESS_RAG_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HARNESS_RAG_VLM_MAX_CALLS=30
HARNESS_RAG_VLM_MAX_IMAGE_BYTES=8000000
HARNESS_RAG_VLM_TIMEOUT_SECONDS=60
# OCR mode for scanned PDFs: vlm, tesseract, hybrid, or off. Hybrid tries the
# configured VLM first, then falls back to local Tesseract.
HARNESS_RAG_PDF_OCR_MODE=hybrid
# Only tesseract/hybrid fallback requires local Tesseract language data.
HARNESS_RAG_PDF_OCR_LANGUAGE=chi_sim+eng
HARNESS_RAG_PDF_OCR_DPI=200

# Retrieval policy: Chinese BM25 + vector RRF + rerank + multimodal diversity.
# HARNESS_RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
HARNESS_RAG_MODALITY_BONUS=0.2
HARNESS_RAG_MIN_RELATIVE_SCORE=0.1
HARNESS_RAG_MAX_PER_PAGE=3
